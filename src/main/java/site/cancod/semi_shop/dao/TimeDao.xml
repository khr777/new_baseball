<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="site.cancod.semi_shop.dao.TimeDao">

	<insert id="insertTimeName">
        INSERT INTO TimeName
        SET timeName = #{timeName},
        userId = #{userId},
        create_time = NOW()
    </insert>
    
</mapper>